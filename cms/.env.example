# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=minimum-32-character-random-secret-string-here
CMS_PASSWORD=your-strong-admin-password

# Optional — used by the main touchpulse.nl site to fetch posts server-side
CMS_API_KEY=random-api-key-for-server-to-server-calls

# Used for logout redirect
NEXT_PUBLIC_CMS_URL=https://cms.touchpulse.ai
