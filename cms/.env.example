# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth — Google OAuth (only @touchpulse.nl accounts allowed)
NEXTAUTH_URL=https://cms.touchpulse.ai
NEXTAUTH_SECRET=minimum-32-character-random-secret-string-here
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Optional — used by the main touchpulse.nl site to fetch posts server-side
CMS_API_KEY=random-api-key-for-server-to-server-calls
